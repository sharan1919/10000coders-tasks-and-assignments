def function_two():
    # Local variable for function_two
    f2_var = "Inside Function Two"
    print("\n--- Function Two Execution ---")
    print(f"Accessing Global: {global_y}")
    print(f"Accessing Local: {f2_var}")

def function_three():
    # Local variable for function_three
    f3_var = "Inside Function Three"
    print("\n--- Function Three Execution ---")
    print(f"Accessing Global: {global_z}")
    print(f"Accessing Local: {f3_var}")

# --- Execution ---
function_one()
function_two()
function_three()

# --- Accessing Function Variables Outside ---
print("\n--- Testing Outside Access ---")
print(f"Global Access Check: {global_x} -> Success")

