# --- GLOBAL VARIABLES ---
global_x = "I am Global X"
global_y = "I am Global Y"
global_z = "I am Global Z"

def function_one():
    # Local variable for function_one
    f1_var = "Inside Function One"
    print("--- Function One Execution ---")
    print(f"Accessing Global: {global_x}")
    print(f"Accessing Local: {f1_var}")
