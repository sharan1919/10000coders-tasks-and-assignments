# 1. Reverse a String
# Objective: Reverse "hello" using a for loop
original_str = "hello"
reversed_str = ""

for char in original_str:
    reversed_str = char + reversed_str  # Adding each character to the front

print(f"Original String: {original_str}")
print(f"Reversed String: {reversed_str}")
print("-" * 30)


# 2. Reverse a List
# Objective: Print [10, 20, 30, 40, 50] in reverse order using a for loop
original_list = [10, 20, 30, 40, 50]

print("Original List:", original_list)
print("List Elements in Reverse:")

# range(start, stop, step) 
# We start at the last index and move backwards to index 0
for i in range(len(original_list) - 1, -1, -1):
    print(original_list[i], end=" ")
print("\n" + "-" * 30)


# 3. Remove Duplicates from a String
# Objective: Remove duplicates from "programming"
input_str = "programming"
unique_str = ""

for char in input_str:
    if char not in unique_str:
        unique_str += char

print(f"String with Duplicates: {input_str}")
print(f"String without Duplicates: {unique_str}")
print("-" * 30)


# 4. Remove Duplicates from a List
# Objective: Remove duplicates from [1, 2, 2, 3, 4, 3, 5]
input_list = [1, 2, 2, 3, 4, 3, 5]
unique_list = []

for item in input_list:
    if item not in unique_list:
        unique_list.append(item)

print(f"List with Duplicates: {input_list}")
print(f"List without Duplicates: {unique_list}")
