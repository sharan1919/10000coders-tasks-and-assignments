-- ---------------------------------------------------------
-- 3. Logical Operators: OR & NOT
-- ---------------------------------------------------------

-- OR Operator: Returns records if any of the conditions are true.
-- Task: Find products that are either from Apple OR have a price less than 100.
SELECT * FROM products 
WHERE brand = 'Apple' OR price < 100;

-- NOT Operator: Displays a record if the condition(s) is NOT true.
-- Task: Find products that are NOT in the 'Electronics' category.
SELECT * FROM products 
WHERE NOT category = 'Electronics';

-- ---------------------------------------------------------
-- 4. Special Operators: BETWEEN, IN, LIKE, IS NULL
-- ---------------------------------------------------------

-- BETWEEN: Selects values within a given range (Inclusive).
-- Task: Find products priced between 500 and 1000.
SELECT name, price FROM products 
WHERE price BETWEEN 500 AND 1000;

-- IN: Specify multiple possible values for a column.
-- Task: Find products belonging to Apple, Samsung, or Dell.
SELECT * FROM products 
WHERE brand IN ('Apple', 'Samsung', 'Dell');

-- LIKE: Search for a specified pattern in a column.
-- (%) represents zero, one, or multiple characters.
-- Task: Find products that start with the word 'Air'.
SELECT * FROM products 
WHERE name LIKE 'Air%';

-- IS NULL / IS NOT NULL: Used to check for empty (NULL) values.
-- Task: Check for products where the category is listed.
SELECT * FROM products 
WHERE category IS NOT NULL;

-- ---------------------------------------------------------
-- 5. Summary of Learning
-- ---------------------------------------------------------
/*
- OR: Useful for broadening searches (e.g., multiple brands).
- NOT: Essential for filtering out unwanted data (e.g., out-of-stock items).
- BETWEEN: Cleaner than using >= AND <= for ranges.
- IN: Much more readable than writing multiple OR statements.
- LIKE: Powerful for text-based pattern matching using wildcards.
*/
