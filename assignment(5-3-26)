-- 1. Table Creation
CREATE TABLE products (
    id INT PRIMARY KEY,
    name VARCHAR(50),
    category VARCHAR(50),
    brand VARCHAR(50),
    price DECIMAL(10,2),
    stock INT,
    is_available BOOLEAN,
    rating DECIMAL(2,1)
);

