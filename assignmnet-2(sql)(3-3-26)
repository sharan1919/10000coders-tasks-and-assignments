# 3. Identity Operators
list_a = [1, 2, 3]
list_b = [1, 2, 3]
list_c = list_a

print(f"Does list_a have same value as list_b? {list_a == list_b}") # True
print(f"Are list_a and list_b the SAME object? {list_a is list_b}")  # False (Different memory)
print(f"Are list_a and list_c the SAME object? {list_a is list_c}")  # True (Same memory)
